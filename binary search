n = int(input("Enter the size of the element: "))
l = []
for i in range(n):
    number = int(input("Enter the number: "))
    l.append(number)
l = l.sort()
search_element = int(input("Enter the search element: "))
low = 0
high = n - 1
while low <= high:
    mid_index = (high -low)//2
    if search_element == l[mid_index]:
        print("Element found.")
    else:
        if search_element < l[mid_index]:
            high = mid_index
        else:
            low = l[mid_index]
        print("element found")
